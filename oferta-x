<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ecossistema Vox-IA | LeadVox — Captação + IA + CRM previsível</title>
<meta name="description" content="Tráfego que traz o lead, IA que responde na hora e CRM que converte com previsibilidade. Ecossistema Vox-IA: gestão de Meta Ads e Google Ads + IA + CRM no seu WhatsApp por R$ 1.769/mês, tudo incluso.">
<meta name="theme-color" content="#070d1c">
<meta property="og:title" content="Ecossistema Vox-IA | LeadVox">
<meta property="og:description" content="Captação + IA + CRM num só lugar. Meta Ads + Google Ads + IA + CRM por R$ 1.769/mês, tudo incluso.">
<meta property="og:type" content="website">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
  :root{
    --navy-950:#070d1c;
    --navy-900:#0a1326;
    --navy-850:#0e1830;
    --navy-800:#13203a;
    --navy-card:#101b32;
    --line:rgba(255,255,255,.08);
    --line-strong:rgba(255,255,255,.14);
    --green:#1fe07a;
    --green-deep:#13b462;
    --green-soft:#7defb3;
    --gold:#e7c884;
    --gold-soft:#f3e2b8;
    --gold-deep:#c9a45c;
    --ink:#eaf1f8;
    --muted:#9aabc4;
    --dim:#6b7c97;
    --maxw:1140px;
    --r:18px;
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{
    background:var(--navy-950);
    color:var(--ink);
    font-family:'Inter',system-ui,sans-serif;
    line-height:1.6;
    -webkit-font-smoothing:antialiased;
    overflow-x:hidden;
  }
  body::before{
    content:"";position:fixed;inset:0;z-index:0;pointer-events:none;
    background:
      radial-gradient(720px 480px at 78% -8%, rgba(31,224,122,.10), transparent 60%),
      radial-gradient(620px 420px at 8% 12%, rgba(231,200,132,.06), transparent 55%);
  }
  .wrap{max-width:var(--maxw);margin:0 auto;padding:0 22px;position:relative;z-index:1}
  h1,h2,h3{font-family:'Sora',sans-serif;line-height:1.1;letter-spacing:-.02em}
  .mono{font-family:'JetBrains Mono',monospace;font-variant-numeric:tabular-nums}
  a{color:inherit;text-decoration:none}

  /* eyebrow */
  .eyebrow{
    display:inline-flex;align-items:center;gap:8px;
    font-family:'JetBrains Mono',monospace;font-size:.72rem;letter-spacing:.18em;
    text-transform:uppercase;color:var(--green-soft);
    border:1px solid var(--line);border-radius:999px;padding:7px 14px;
    background:rgba(31,224,122,.05);
  }
  .eyebrow.gold{color:var(--gold-soft);background:rgba(231,200,132,.06)}
  .dot{width:7px;height:7px;border-radius:50%;background:var(--green);box-shadow:0 0 0 4px rgba(31,224,122,.18)}
  .dot.live{animation:livePulse 2s ease-out infinite}
  @keyframes livePulse{0%{box-shadow:0 0 0 0 rgba(31,224,122,.45)}70%{box-shadow:0 0 0 8px rgba(31,224,122,0)}100%{box-shadow:0 0 0 0 rgba(31,224,122,0)}}
  .dot.gold{background:var(--gold);box-shadow:0 0 0 4px rgba(231,200,132,.16)}

  /* buttons */
  .btn{
    display:inline-flex;align-items:center;justify-content:center;gap:9px;
    font-family:'Sora',sans-serif;font-weight:700;font-size:1rem;
    padding:15px 26px;border-radius:13px;cursor:pointer;border:0;
    transition:transform .15s ease, box-shadow .25s ease, background .2s ease;
  }
  .btn-primary{background:var(--green);color:#04130a;box-shadow:0 10px 30px rgba(31,224,122,.28)}
  .btn-primary:hover{transform:translateY(-2px);box-shadow:0 16px 40px rgba(31,224,122,.4)}
  .btn-ghost{background:transparent;color:var(--ink);border:1px solid var(--line-strong)}
  .btn-ghost:hover{border-color:var(--green);color:var(--green-soft)}
  .btn-lg{padding:18px 34px;font-size:1.08rem}

  /* top bar */
  header{
    position:sticky;top:0;z-index:50;
    background:rgba(7,13,28,.82);backdrop-filter:blur(14px);
    border-bottom:1px solid var(--line);
  }
  .nav{display:flex;align-items:center;justify-content:space-between;height:66px}
  .brand{display:flex;align-items:center;gap:11px;font-family:'Sora',sans-serif;font-weight:800;font-size:1.25rem;letter-spacing:-.03em}
  /* ====== SUBSTITUA o SVG abaixo pelo seu logo base64: <img src="data:image/png;base64,..." alt="LeadVox" style="height:30px"> ====== */
  .logo-img{height:34px;width:auto;flex:none;display:block}
  .brand b{color:var(--green)}
  .nav-cta{display:flex;align-items:center;gap:14px}
  .nav-vagas{font-family:'JetBrains Mono',monospace;font-size:.74rem;color:var(--gold-soft);display:none}
  @media(min-width:760px){.nav-vagas{display:inline}}

  /* announcement strip */
  .strip{
    background:linear-gradient(90deg, rgba(231,200,132,.12), rgba(31,224,122,.10));
    border-bottom:1px solid var(--line);
    font-family:'JetBrains Mono',monospace;font-size:.76rem;letter-spacing:.04em;
    text-align:center;padding:9px 16px;color:var(--gold-soft);position:relative;z-index:2;
  }
  .strip b{color:var(--ink)}

  /* hero */
  .hero{padding:74px 0 40px;position:relative;overflow:hidden}
  .hero::before{content:"";position:absolute;inset:0;z-index:0;pointer-events:none;
    background-image:linear-gradient(rgba(31,224,122,.055) 1px,transparent 1px),linear-gradient(90deg,rgba(31,224,122,.055) 1px,transparent 1px);
    background-size:46px 46px;
    -webkit-mask:radial-gradient(115% 80% at 72% 2%,#000 28%,transparent 72%);mask:radial-gradient(115% 80% at 72% 2%,#000 28%,transparent 72%);
    animation:gridDrift 20s linear infinite}
  @keyframes gridDrift{to{background-position:46px 46px}}
  .hero::after{content:"";position:absolute;top:-12%;right:-4%;width:480px;height:480px;z-index:0;pointer-events:none;
    background:radial-gradient(circle,rgba(31,224,122,.14),transparent 62%);filter:blur(26px);animation:auroraFloat 13s ease-in-out infinite}
  @keyframes auroraFloat{0%,100%{transform:translate(0,0)}50%{transform:translate(-34px,26px)}}
  .hero-grid{display:grid;grid-template-columns:1fr;gap:46px;align-items:center}
  @media(min-width:980px){.hero-grid{grid-template-columns:1.05fr .95fr}}
  .hero h1{font-size:clamp(2.1rem,5.4vw,3.55rem);font-weight:800;margin:20px 0 18px}
  .hero h1 .hl{position:relative;white-space:nowrap;color:var(--green);
    background:linear-gradient(100deg,var(--green) 0%,#6ff0ad 40%,var(--green) 70%);background-size:220% 100%;
    -webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;
    animation:hlShift 6s linear infinite}
  @keyframes hlShift{to{background-position:220% 0}}
  .hero p.lead{font-size:1.16rem;color:var(--muted);max-width:36ch;margin-bottom:30px}
  .hero-actions{display:flex;flex-wrap:wrap;gap:14px;margin-bottom:24px}
  .hero-trust{display:flex;flex-wrap:wrap;gap:18px;font-size:.86rem;color:var(--dim)}
  .hero-trust span{display:flex;align-items:center;gap:7px}
  .chk{color:var(--green)}

  /* hero offer card */
  .offer-card{
    background:linear-gradient(180deg,var(--navy-850),var(--navy-900));
    border:1px solid var(--line-strong);border-radius:22px;padding:26px;
    box-shadow:0 30px 70px rgba(0,0,0,.45);position:relative;overflow:hidden;
  }
  .offer-card::before{content:"";position:absolute;inset:0;border-radius:22px;padding:1px;
    background:linear-gradient(135deg,rgba(31,224,122,.5),transparent 40%,rgba(231,200,132,.4));
    -webkit-mask:linear-gradient(#000 0 0) content-box,linear-gradient(#000 0 0);
    -webkit-mask-composite:xor;mask-composite:exclude;pointer-events:none;opacity:.7}
  .offer-card .tag{font-family:'JetBrains Mono',monospace;font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:var(--gold-soft)}
  .offer-card .plan{font-family:'Sora',sans-serif;font-weight:800;font-size:1.5rem;margin:6px 0 14px}
  .price-row{display:flex;align-items:flex-end;gap:10px;margin-bottom:4px}
  .price{font-family:'Sora',sans-serif;font-weight:800;font-size:3rem;color:var(--green);letter-spacing:-.03em;line-height:1}
  .price .cents{font-size:1.5rem}
  .price-per{color:var(--muted);font-size:.95rem;padding-bottom:7px}
  .price-sub{color:var(--dim);font-size:.84rem;margin-bottom:18px}
  .offer-mini{border-top:1px solid var(--line);padding-top:16px;margin-bottom:18px}
  .offer-mini li{list-style:none;display:flex;align-items:center;gap:10px;font-size:.92rem;color:var(--muted);padding:5px 0}
  .offer-mini li .chk{color:var(--green);flex:none}
  .offer-card .btn{width:100%}
  .bonus-flag{
    margin-top:14px;text-align:center;font-family:'JetBrains Mono',monospace;
    font-size:.8rem;color:var(--gold-soft);
  }
  .bonus-flag b{color:var(--gold)}

  /* section scaffolding */
  section{padding:64px 0;position:relative}
  .sec-head{max-width:640px;margin-bottom:40px}
  .sec-head.center{margin-left:auto;margin-right:auto;text-align:center}
  .sec-head h2{font-size:clamp(1.7rem,3.8vw,2.5rem);font-weight:800;margin:14px 0 14px}
  .sec-head p{color:var(--muted);font-size:1.06rem}

  /* problem cards */
  .prob-grid{display:grid;grid-template-columns:1fr;gap:16px}
  @media(min-width:680px){.prob-grid{grid-template-columns:1fr 1fr}}
  @media(min-width:980px){.prob-grid{grid-template-columns:repeat(3,1fr)}}
  .prob{
    background:var(--navy-card);border:1px solid var(--line);border-radius:var(--r);
    padding:24px;transition:border-color .2s ease,transform .2s ease;
  }
  .prob:hover{border-color:var(--line-strong);transform:translateY(-3px)}
  .prob .ic{font-size:1.4rem;width:46px;height:46px;display:grid;place-items:center;border-radius:12px;
    background:rgba(255,80,80,.08);border:1px solid rgba(255,90,90,.18);margin-bottom:14px}
  .prob h3{font-size:1.08rem;font-weight:700;margin-bottom:7px}
  .prob p{color:var(--muted);font-size:.95rem}

  /* solution / what is */
  .what{background:linear-gradient(180deg,transparent,rgba(31,224,122,.03),transparent)}
  .feat-grid{display:grid;grid-template-columns:1fr;gap:16px}
  @media(min-width:680px){.feat-grid{grid-template-columns:1fr 1fr}}
  .feat{
    display:flex;gap:16px;align-items:flex-start;
    background:var(--navy-card);border:1px solid var(--line);border-radius:var(--r);padding:22px;
    transition:border-color .2s ease,transform .2s ease;
  }
  .feat:hover{border-color:rgba(31,224,122,.35);transform:translateY(-3px)}
  .feat .ic{flex:none;width:48px;height:48px;border-radius:12px;display:grid;place-items:center;
    background:rgba(31,224,122,.1);border:1px solid rgba(31,224,122,.22);color:var(--green);font-size:1.35rem}
  .feat h3{font-size:1.08rem;font-weight:700;margin-bottom:5px}
  .feat p{color:var(--muted);font-size:.93rem}

  /* channels row */
  .channels{display:flex;flex-wrap:wrap;gap:12px;margin-top:26px;justify-content:center}
  .chan{
    display:flex;align-items:center;gap:9px;font-size:.9rem;color:var(--ink);
    border:1px solid var(--line);border-radius:999px;padding:9px 16px;background:var(--navy-850);
  }
  .chan .b{width:9px;height:9px;border-radius:50%;background:var(--green)}

  /* pillar labels (ecossistema) */
  .pillar{margin:38px 0 18px;display:flex;align-items:center;gap:14px}
  .pillar:first-of-type{margin-top:8px}
  .pillar .num{flex:none;width:30px;height:30px;border-radius:9px;display:grid;place-items:center;
    font-family:'JetBrains Mono',monospace;font-weight:700;font-size:.86rem;color:var(--green);
    background:rgba(31,224,122,.1);border:1px solid rgba(31,224,122,.25)}
  .pillar h3{font-size:1.18rem;font-weight:800;letter-spacing:-.01em}
  .pillar h3 small{display:block;font-family:'Inter',sans-serif;font-weight:500;font-size:.84rem;color:var(--dim);letter-spacing:0;margin-top:2px}
  .pillar .rail{flex:1;height:1px;background:linear-gradient(90deg,var(--line-strong),transparent)}

  /* ===== VALUE STACK — signature ===== */
  .stack-sec{padding-top:30px}
  .receipt{
    max-width:660px;margin:0 auto;
    background:linear-gradient(180deg,var(--navy-850),var(--navy-900));
    border:1px solid var(--line-strong);border-radius:22px;overflow:hidden;
    box-shadow:0 36px 90px rgba(0,0,0,.5);
  }
  .receipt-top{padding:24px 26px 18px;border-bottom:1px dashed var(--line-strong);text-align:center}
  .receipt-top .tag{font-family:'JetBrains Mono',monospace;font-size:.72rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold-soft)}
  .receipt-top h3{font-size:1.35rem;font-weight:800;margin-top:6px}
  .receipt-body{padding:10px 26px}
  .line{
    display:flex;align-items:baseline;gap:14px;padding:15px 0;border-bottom:1px solid var(--line);
  }
  .line:last-child{border-bottom:0}
  .line .name{flex:1;min-width:0}
  .line .name strong{display:block;font-weight:600;font-size:1rem;color:var(--ink)}
  .line .name small{color:var(--dim);font-size:.82rem}
  .line .val{font-family:'JetBrains Mono',monospace;font-weight:500;font-size:1rem;white-space:nowrap}
  .line.included .val{color:var(--green-soft)}
  .line.bonus{position:relative}
  .line.bonus .name strong{color:var(--gold-soft)}
  .line.bonus .badge{display:inline-block;font-family:'JetBrains Mono',monospace;font-size:.62rem;letter-spacing:.12em;
    text-transform:uppercase;color:var(--gold);border:1px solid rgba(231,200,132,.3);border-radius:5px;padding:2px 7px;margin-bottom:6px}
  .line.bonus .val{color:var(--gold)}
  .line.bonus .val .strike{text-decoration:line-through;text-decoration-color:rgba(231,200,132,.6);opacity:.85}
  .receipt-total{
    background:rgba(231,200,132,.07);padding:18px 26px;border-top:1px dashed var(--line-strong);
    display:flex;align-items:center;justify-content:space-between;
  }
  .receipt-total .lbl{font-family:'Sora',sans-serif;font-weight:700;font-size:1.02rem;color:var(--gold-soft)}
  .receipt-total .amount{font-family:'JetBrains Mono',monospace;font-weight:700;font-size:1.5rem;color:var(--gold)}
  .receipt-bonus{
    background:rgba(31,224,122,.08);padding:16px 26px;border-top:1px dashed var(--line-strong);
    display:flex;align-items:center;justify-content:space-between;
  }
  .receipt-bonus .lbl{font-family:'Sora',sans-serif;font-weight:700;font-size:1.02rem;color:var(--green-soft)}
  .receipt-bonus .amount{font-family:'JetBrains Mono',monospace;font-weight:700;font-size:1.5rem;color:var(--green)}
  .receipt-pay{padding:24px 26px 26px;text-align:center}
  .receipt-pay .you-pay{font-family:'JetBrains Mono',monospace;font-size:.74rem;letter-spacing:.16em;text-transform:uppercase;color:var(--dim)}
  .receipt-pay .big{display:flex;align-items:flex-end;justify-content:center;gap:10px;margin:6px 0 4px}
  .receipt-pay .big .p{font-family:'Sora',sans-serif;font-weight:800;font-size:3.1rem;color:var(--green);line-height:1;letter-spacing:-.03em}
  .receipt-pay .big .per{color:var(--muted);padding-bottom:8px;font-size:.95rem}
  .receipt-pay .note{color:var(--dim);font-size:.86rem;margin-bottom:20px}
  .receipt-pay .btn{width:100%}
  .save-pill{display:inline-flex;align-items:center;gap:8px;margin-bottom:16px;
    background:rgba(31,224,122,.1);border:1px solid rgba(31,224,122,.3);border-radius:999px;
    padding:8px 16px;font-family:'JetBrains Mono',monospace;font-size:.82rem;color:var(--green-soft)}

  /* comparison */
  .compare{display:grid;grid-template-columns:1fr;gap:18px;max-width:1040px;margin:0 auto}
  @media(min-width:680px){.compare{grid-template-columns:1fr 1fr}}
  @media(min-width:920px){.compare{grid-template-columns:repeat(3,1fr)}}
  .plan-col{background:var(--navy-card);border:1px solid var(--line);border-radius:var(--r);padding:26px;position:relative}
  .plan-col.featured{border-color:rgba(31,224,122,.45);background:linear-gradient(180deg,rgba(31,224,122,.05),var(--navy-card))}
  .plan-col.featured::after{content:"RECOMENDADO";position:absolute;top:-11px;left:26px;
    font-family:'JetBrains Mono',monospace;font-size:.64rem;letter-spacing:.14em;color:#04130a;
    background:var(--green);border-radius:6px;padding:4px 10px;font-weight:700}
  .plan-col .pname{font-family:'Sora',sans-serif;font-weight:800;font-size:1.2rem;margin-bottom:3px}
  .plan-col.featured .pname{color:var(--green)}
  .plan-col .pprice{font-family:'JetBrains Mono',monospace;font-size:1.9rem;font-weight:700;margin:4px 0 2px}
  .plan-col .pper{color:var(--dim);font-size:.82rem;margin-bottom:18px}
  .plan-col ul{list-style:none}
  .plan-col li{display:flex;align-items:flex-start;gap:10px;padding:8px 0;font-size:.93rem;color:var(--muted);border-top:1px solid var(--line)}
  .plan-col li:first-child{border-top:0}
  .plan-col li .mk{flex:none;margin-top:2px}
  .mk.yes{color:var(--green)}.mk.no{color:var(--dim)}
  .plan-col li.off{color:var(--dim)}

  /* guarantee */
  .guarantee{
    max-width:860px;margin:0 auto;display:flex;flex-wrap:wrap;gap:26px;align-items:center;
    background:linear-gradient(135deg,var(--navy-850),var(--navy-900));
    border:1px solid var(--line-strong);border-radius:22px;padding:34px;
  }
  .seal{flex:none;width:104px;height:104px;border-radius:50%;display:grid;place-items:center;
    border:2px dashed rgba(231,200,132,.5);color:var(--gold);font-family:'Sora',sans-serif;
    font-weight:800;font-size:.72rem;text-align:center;line-height:1.2;letter-spacing:.04em}
  .seal.seal-green{border-color:rgba(31,224,122,.5);color:var(--green-soft)}
  .guarantee .gtext{flex:1;min-width:240px}
  .guarantee h3{font-size:1.3rem;font-weight:800;margin-bottom:8px}
  .guarantee p{color:var(--muted);font-size:.98rem}

  /* faq */
  .faq{max-width:760px;margin:0 auto}
  details{border:1px solid var(--line);border-radius:14px;padding:0 20px;margin-bottom:12px;background:var(--navy-card);transition:border-color .2s}
  details[open]{border-color:var(--line-strong)}
  summary{list-style:none;cursor:pointer;padding:18px 0;font-family:'Sora',sans-serif;font-weight:600;font-size:1.02rem;
    display:flex;justify-content:space-between;align-items:center;gap:14px}
  summary::-webkit-details-marker{display:none}
  summary .plus{flex:none;width:24px;height:24px;border-radius:50%;border:1px solid var(--line-strong);
    display:grid;place-items:center;color:var(--green);transition:transform .25s}
  details[open] summary .plus{transform:rotate(45deg)}
  details p{color:var(--muted);font-size:.96rem;padding:0 0 20px}

  /* final cta */
  .final{text-align:center}
  .final-card{
    max-width:780px;margin:0 auto;background:linear-gradient(135deg,rgba(31,224,122,.08),rgba(231,200,132,.06));
    border:1px solid var(--line-strong);border-radius:24px;padding:48px 30px;
  }
  .final-card h2{font-size:clamp(1.8rem,4vw,2.6rem);font-weight:800;margin-bottom:14px}
  .final-card p{color:var(--muted);font-size:1.08rem;max-width:46ch;margin:0 auto 26px}

  /* footer */
  footer{border-top:1px solid var(--line);padding:40px 0;color:var(--dim);font-size:.86rem}
  .partners{display:flex;flex-direction:column;align-items:center;gap:14px;text-align:center;
    padding-bottom:30px;margin-bottom:30px;border-bottom:1px solid var(--line)}
  .partners .plabel{font-family:'JetBrains Mono',monospace;font-size:.7rem;letter-spacing:.18em;
    text-transform:uppercase;color:var(--gold-soft)}
  .pbadges{display:flex;flex-wrap:wrap;gap:16px;justify-content:center;align-items:center}
  .pbadge{background:#fff;border-radius:12px;padding:12px 18px;display:flex;align-items:center;
    box-shadow:0 8px 24px rgba(0,0,0,.28)}
  .pbadge img{height:34px;width:auto;display:block}
  .foot{display:flex;flex-wrap:wrap;justify-content:space-between;gap:18px;align-items:center}
  .foot a:hover{color:var(--green-soft)}

  /* sticky mobile cta */
  .sticky-cta{
    position:fixed;left:0;right:0;bottom:0;z-index:60;
    background:rgba(7,13,28,.94);backdrop-filter:blur(12px);border-top:1px solid var(--line);
    padding:12px 16px;display:flex;gap:12px;align-items:center;justify-content:space-between;
    transform:translateY(120%);transition:transform .35s ease;
  }
  .sticky-cta.show{transform:translateY(0)}
  .sticky-cta .sp{font-family:'JetBrains Mono',monospace}
  .sticky-cta .sp b{color:var(--green);font-size:1.15rem}
  .sticky-cta .sp small{display:block;color:var(--dim);font-size:.7rem}
  .sticky-cta .btn{padding:12px 20px}
  @media(min-width:860px){.sticky-cta{display:none}}

  /* reveal anim */
