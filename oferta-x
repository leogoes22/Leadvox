        <span class="pbadge"><img src="data:image/png;base64," alt="Google Ads Certified Partner"></span>
      </div>
    </div>
    <div class="foot">
      <span>&copy; <span id="yr"></span> LeadVox &middot; Ecossistema de capta&ccedil;&atilde;o com IA + CRM</span>
      <span><a href="https://leadvox.com.br">leadvox.com.br</a></span>
    </div>
  </div>
</footer>

<!-- STICKY MOBILE CTA -->
<div class="sticky-cta" id="stickyCta">
  <div class="sp"><b>R$ 1.769</b><small>/mês · + R$ 7.172 em bônus no 1º mês</small></div>
  <a href="#contato" class="btn btn-primary">Quero o Ecossistema</a>
</div>

<script>
  document.getElementById('yr').textContent = new Date().getFullYear();

  // scroll reveal
  const io = new IntersectionObserver((entries)=>{
    entries.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target);} });
  }, {threshold:.12, rootMargin:'0px 0px -40px 0px'});
  document.querySelectorAll('.reveal').forEach(el=>io.observe(el));

  // count-up no total de bônus
  const totalEl = document.getElementById('bonusTotal');
  const reduce = window.matchMedia('(prefers-reduced-motion:reduce)').matches;
  let counted = false;
  const fmt = n => 'R$ ' + n.toLocaleString('pt-BR');
  const countIO = new IntersectionObserver((entries)=>{
    entries.forEach(e=>{
      if(e.isIntersecting && !counted){
        counted = true;
        if(reduce){ totalEl.textContent = fmt(8941); return; }
        const target = 8941; const dur = 1100; const start = performance.now();
        const step = (now)=>{
          const p = Math.min((now-start)/dur,1);
          const val = Math.floor((1-Math.pow(1-p,3))*target);
          totalEl.textContent = fmt(val);
          if(p<1) requestAnimationFrame(step); else totalEl.textContent = fmt(target);
        };
        requestAnimationFrame(step);
      }
    });
  }, {threshold:.6});
  countIO.observe(totalEl);

  // sticky cta aparece depois do hero
  const sticky = document.getElementById('stickyCta');
  const heroMini = document.getElementById('oferta-mini');
  const stickyIO = new IntersectionObserver((entries)=>{
    entries.forEach(e=>{ sticky.classList.toggle('show', !e.isIntersecting); });
  }, {threshold:0});
  if(heroMini) stickyIO.observe(heroMini);
</script>
</body>
</html>
